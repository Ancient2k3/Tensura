-- Auto Attack: Blox Fruits (Fixed) --
local ws = game:GetService("Workspace")
local plrs = game:GetService("Players")
local rs = game:GetService("RunService")
local rls = game:GetService("ReplicatedStorage")
local mdls = rls:WaitForChild("Modules")
local net = mdls:WaitForChild("Net")
local cd = net:WaitForChild("RE/RegisterAttack")
local rh = net:WaitForChild("RE/RegisterHit")

local plr = plrs.LocalPlayer
local valid_wp = {"Melee", "Sword", "Blox Fruit"}
local valid_body_parts = {"HumanoidRootPart", "LeftUpperArm", "LeftLowerArm", "LeftHand", "RightUpperArm", "RightLowerArm", "RightHand", "LeftUpperLeg", "LeftLowerLeg", "LeftFoot", "RightUpperLeg", "RightLowerLeg", "RightFoot"}

function random_str()
  local str = "qwertyuiopasdfghjklzxcvbnm1234567890"
  local result = ""
  for index = 1, 4 do
    local random_index = math.random(1, #str)
    result = result .. str:sub(random_index, random_index)
  end return result
end

local uid = tostring(plr.UserId):sub(2, 5) .. random_str()

function target_alive(t)
  local hmoid = t and t.Character and t:FindFirstChildOfClass("Humanoid")
  if hmoid and hmoid.Health > 0 then
    return true
  end return false
end

function find_enm()
  local data = {n = nil, m = math.huge, r = 60}
  for _, enm in pairs(plrs:GetPlayers()) do
    if enm ~= plr and enm.Character and enm.Character:FindFirstChild("HumanoidRootPart") then
      local dist = (enm.Character.HumanoidRootPart.Position - plr.Character.HumanoidRootPart.Position).magnitude
      if dist < data.m and dist <= data.r and target_alive(enm) then
        data.m = dist
        data.n = enm
      end
    end
  end return data.n
end

function auto_fight()
  local enm_founded = find_enm()
  local tool_equip = plr.Character:FindFirstChildOfClass("Tool")
  if #plrs:GetPlayers() > 0 and enm_founded ~= nil then
    if tool_equip and table.find(valid_wp, tool_equip.ToolTip) then
      cd:FireServer(0.5)
      rh:FireServer(enm_founded.Character[valid_body_parts[math.random(1, #valid_body_parts)]], {}, uid)
    end
  end
end

rs.RenderStepped:Connect(function()
  if _G.AutoATK_PLRS_Enabled and target_alive(plr) then
    auto_fight()
  end
end)
